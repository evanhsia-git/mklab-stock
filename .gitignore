# 不進版本控制
.DS_Store
*.log
node_modules/
.obsidian/
.vscode/

# 原始日線資料（保留外部，不進 repo）
data/raw/
data/daily-*.csv

# 但 Build-Time 生成的 JSON（含 history 切片）要進 repo（Static-First / Fork-First）
!data/*.json
!data/history/
!data/history/*.json

# Python 快取 / 本地 QA 輸出
__pycache__/
*.pyc
qa-result.json

# 私有/環境
.env
.env.*
secrets.*
