{
  "version": "1.0.0",
  "updated": "2026-07-19",
  "description": "統一管理各市場代碼映射（TWSE、TPEX、Yahoo Finance 等），避免程式中硬寫代碼轉換",
  "sources": {
    "TWSE": {
      "name": "台灣證券交易所",
      "api_base": "https://openapi.twse.com.tw/v1",
      "endpoints": {
        "daily": "exchangeReport/STOCK_DAY_ALL",
        "bwibbu": "exchangeReport/BWIBBU_ALL",
        "profitability": "opendata/t187ap06_L",
        "balance_sheet": "opendata/t187ap05_L",
        "income_statement": "opendata/t187ap03_L"
      },
      "code_format": "4-6位數字，部分ETF含字母尾碼",
      "example": "2330, 0050.TW"
    },
    "TPEX": {
      "name": "證券櫃檯買賣中心",
      "api_base": "https://www.tpex.org.tw/openapi/v1",
      "endpoints": {
        "daily": "tpex_mainboard_daily_close_quotes?l=zh-tw",
        "bwibbu": "tpex_mainboard_daily_bwibbu?l=zh-tw"
      },
      "code_format": "4-6位數字",
      "example": "6488, 8069"
    },
    "YAHOO": {
      "name": "Yahoo Finance",
      "library": "yfinance",
      "code_format": "{代碼}.TW (上市) / {代碼}.TWO (上櫃) / {代碼} (美股/港股/中股)",
      "examples": {
        "TWSE": "2330.TW",
        "TPEX": "6488.TWO",
        "US": "AAPL, MSFT, NVDA",
        "HK": "0700.HK, 09988.HK",
        "CN": "600519.SS, 000001.SZ",
        "INDEX": "^TWII, ^GSPC, ^IXIC, ^HSI, ^N225"
      }
    }
  },
  "markets": {
    "TWSE": {
      "name": "上市",
      "yahoo_suffix": ".TW",
      "indices": ["^TWII"]
    },
    "TPEX": {
      "name": "上櫃",
      "yahoo_suffix": ".TWO",
      "indices": []
    },
    "EMERGING": {
      "name": "興櫃",
      "yahoo_suffix": null,
      "indices": []
    }
  },
